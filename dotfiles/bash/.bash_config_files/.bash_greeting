# ----------------------------------------------------------------------------
# -- BASH Login Shell Greeting Display ---------------------------------------
#
# This file defines a custom greeting message for a Bash Shell interactive
# login.  It currently displays system stats and information to the user.
#
# This file is intended to be "sourced" by .bashrc:
#
#    if [ -f /<path>/.bash_greeting ]; then
#     source /<path>/.bash_greeting
#    fi
#
# ----------------------------------------------------------------------------


# -- Fetch this file's directory ---------------------------------------------
SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )


# -- Source Common Functions, if not present ---------------------------------
if [ -z "$FILE_SOURCED_FUNCTIONS_COMMON" ]; then
   if [ -f  "${SCRIPT_DIR}/.bash_functions_common" ]; then
     source "${SCRIPT_DIR}/.bash_functions_common"
   fi
fi


# -- Environment controls for greeting behavior ------------------------------
# ENV_GREETING_ENABLED:   Show greeting? (default: 1)
# ENV_GREETING_TIMEOUT:   Max seconds per function (default: 2)
# ENV_GREETING_MINIMAL:   Skip expensive ops? (default: 0)
export ENV_GREETING_ENABLED="${ENV_GREETING_ENABLED:-1}"
export ENV_GREETING_TIMEOUT="${ENV_GREETING_TIMEOUT:-2}"
export ENV_GREETING_MINIMAL="${ENV_GREETING_MINIMAL:-0}"

# Skip if greeting explicitly disabled
if [[ "${ENV_GREETING_ENABLED}" != "1" ]]; then
  return
fi


# -- Check command availability upfront ----------------------------------------
__GREETING_HAS_BC=0
__GREETING_HAS_LSCPU=0
__GREETING_HAS_TIMEOUT=0

command -v bc      >/dev/null 2>&1  &&       __GREETING_HAS_BC=1
command -v lscpu   >/dev/null 2>&1  &&    __GREETING_HAS_LSCPU=1
command -v timeout >/dev/null 2>&1  &&  __GREETING_HAS_TIMEOUT=1


# ----------------------------------------------------------------------------
#  FUNCTION NAME: _greeting_timeout_exec
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Execute a command with timeout wrapper
#                  Returns output if successful, returns error message on timeout
# ----------------------------------------------------------------------------
#  PARAMETERS   : $1  = default return value if command fails
#                 $2+ = command and arguments to execute
# ----------------------------------------------------------------------------
function _greeting_timeout_exec()
{
  local timeout_sec="${ENV_GREETING_TIMEOUT}"
  local default_val="${1}"
  shift

  if [[ ${__GREETING_HAS_TIMEOUT} -eq 1 ]]; then
    timeout "${timeout_sec}" "$@" 2>/dev/null || echo "<timeout>"
  else
    "$@" 2>/dev/null || echo "${default_val}"
  fi
} # _greeting_timeout_exec()


# ----------------------------------------------------------------------------
#  FUNCTION NAME: _greeting_is_slow_filesystem
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Detect if a path is on a slow filesystem (NFS, CIFS, FUSE, SSHFS)
#                  Returns exit code 0 if slow, 1 if fast
# ----------------------------------------------------------------------------
#  PARAMETERS   : $1 = path to check (default: current directory)
# ----------------------------------------------------------------------------
function _greeting_is_slow_filesystem()
{
  local path="${1:-.}"
  mount | awk -v p="$path" '$3 ~ /nfs|cifs|fuse|sshfs/ {exit 0} END {exit 1}'
} # _greeting_is_slow_filesystem()


# ----------------------------------------------------------------------------
#  FUNCTION NAME: _greeting_calc
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Perform arithmetic calculation with bc or awk fallback
#                  Returns result as floating-point with scale=1
# ----------------------------------------------------------------------------
#  PARAMETERS   : $1 = arithmetic expression (e.g. "1024 / 1024")
# ----------------------------------------------------------------------------
function _greeting_calc()
{
  local expr="${1}"

  if [[ ${__GREETING_HAS_BC} -eq 1 ]]; then
    echo "scale=1; ${expr}" | bc 2>/dev/null || echo "<calc_error>"
  else
    # Fallback using printf (integer-only)
    printf "%.0f\n" "$(awk "BEGIN {print ${expr}}")" 2>/dev/null || echo "<calc_error>"
  fi
} # _greeting_calc()


# ----------------------------------------------------------------------------
#  FUNCTION NAME: display_system_uptime
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Display the formatted system uptime
#                  ex:  1 week, 3 days, 21 hours, 45 minutes
# ----------------------------------------------------------------------------
#  PARAMETERS   : na
# ----------------------------------------------------------------------------
function display_system_uptime()
{
  local UPTIME

  # Verify uptime command exists
  if ! command -v uptime >/dev/null 2>&1; then
    echo "<unavailable>"
    return
  fi

  # Attempt #1: Check if 'uptime' supports the "pretty format" option (-p)
  if uptime -p >/dev/null 2>&1; then
    # Pretty-format: Supported
    # Note: When the system is up for less than '0' minutes, then
    #       'uptime -p' returns ONLY 'up', so set a default value
    UPTIME_SET_OR_EMPTY=$(uptime -p 2>/dev/null | awk -F 'up ' '{print $2}')
    UPTIME=${UPTIME_SET_OR_EMPTY:-'less than a minute'}
  else
    # Attempt #2: Pretty-format unsupported, parse standard uptime output
    # Parse the results and format to: days, hours, minutes
    UPTIME=$(uptime 2>/dev/null | sed -E 's/^[^,]*up *//; s/mins/minutes/; s/hrs?/hours/;
    s/([[:digit:]]+):0?([[:digit:]]+)/\1 hours, \2 minutes/;
    s/^1 hours/1 hour/; s/ 1 hours/ 1 hour/;
    s/min,/minutes,/; s/ 0 minutes,/ less than a minute,/; s/ 1 minutes/ 1 minute/;
    s/  / /; s/, *[[:digit:]]* users?.*//')
  fi

  # Fallback if both methods failed
  if [[ -z "${UPTIME}" ]]; then
    UPTIME="<unavailable>"
  fi

  echo "${UPTIME}"

} # display_system_uptime()


# ----------------------------------------------------------------------------
#  FUNCTION NAME: display_processor_name
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Display the formatted processor name
# ----------------------------------------------------------------------------
#  PARAMETERS   : na
# ----------------------------------------------------------------------------
function display_processor_name()
{
  # Attempt #1:  Parse /proc/cpuinfo
  if [[ -f /proc/cpuinfo ]]; then
    CPU_NAME=$(awk -F':' '/model name/{ print $2 }' /proc/cpuinfo | head -n 1 | tr -s " " | sed 's/^ //')
  fi

  # Attempt #2:  Parse /proc/cpuinfo (alternate format)
  if [[ -z "$CPU_NAME" ]]; then
    if [[ -f /proc/cpuinfo ]]; then
      CPU_NAME=$(awk -F':' '/Model/{ print $2 }' /proc/cpuinfo | head -n 1 | tr -s " " | sed 's/^ //')
    fi
  fi

  # Attempt #3:  Parse lscpu results
  if [[ -z "$CPU_NAME" ]]; then
    # Check if available
    if lscpu >/dev/null 2>&1; then
      CPU_NAME=$(lscpu | grep 'Model name' | cut -f 2 -d ":" | awk '{$1=$1}1')
    fi
  fi

  # Attempt #4:  Parse sysctl results (MacOS)
  if [[ -z "$CPU_NAME" ]]; then
    # Check if available
    if sysctl -n machdep.cpu.brand_string  >/dev/null 2>&1; then
      CPU_NAME=$(sysctl -n machdep.cpu.brand_string)
    fi
  fi

  # Attempt #5:  Parse sysctl results (FreeBSD)
  if [[ -z "$CPU_NAME" ]]; then
    # Check if available
    if sysctl -n hw.model  >/dev/null 2>&1; then
      CPU_NAME=$(sysctl -n hw.model)
    fi
  fi


  # Out of options:  Default value
  if [[ -z "$CPU_NAME" ]]; then
    CPU_NAME="<unavailable>"
  fi

  echo "${CPU_NAME}"

} # display_processor_name()


# ----------------------------------------------------------------------------
#  FUNCTION NAME: display_num_cpu_cores
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Display the physical core-count of the CPU
#                  [Sockets] x [Cores-Per-Socket]
# ----------------------------------------------------------------------------
#  PARAMETERS   : na
# ----------------------------------------------------------------------------
function display_num_cpu_cores()
{
  local num_sockets=1
  local cores_per_socket=1

  # Attempt #1: Check for 'lscpu' command
  if lscpu >/dev/null 2>&1; then
    num_sockets=$(lscpu | grep "Socket(s):" | awk '{ print $2 }' | head -1 | tail -1 | tr -d '\r ')

    # system uses "clusters" rather than sockets? (RaspPi)
    if [[ "${num_sockets}" == "-" ]]; then
      num_clusters=$(lscpu | grep "Cluster(s):" | awk '{ print $2 }' | head -1 | tail -1 | tr -d '\r ')

      cores_per_cluster=$(lscpu | grep "Core(s) per cluster" | awk '{ print $4 }' | head -1 | tail -1 | tr -d '\r ')
      NUM_CPU_CORES=$(_greeting_calc "${num_clusters} * ${cores_per_cluster}")
    else
      cores_per_socket=$(lscpu | grep "Core(s) per socket" | awk '{ print $4 }' | head -1 | tail -1 | tr -d '\r ')
      NUM_CPU_CORES=$(_greeting_calc "${num_sockets} * ${cores_per_socket}")
    fi
  fi

  # Attempt #2: macOS sysctl
  if [[ -z "$NUM_CPU_CORES" ]]; then
    if sysctl -n hw.physicalcpu >/dev/null 2>&1; then
      NUM_CPU_CORES=$(sysctl -n hw.physicalcpu)
    fi
  fi

  # Attempt #3: nproc command (GNU/Linux)
  if [[ -z "$NUM_CPU_CORES" ]]; then
    if command -v nproc >/dev/null 2>&1; then
      # nproc --all gives physical cores on some systems
      NUM_CPU_CORES=$(nproc --all 2>/dev/null)
    fi
  fi

  # Attempt #4: /proc/cpuinfo parsing (Linux)
  if [[ -z "$NUM_CPU_CORES" ]]; then
    if [[ -f /proc/cpuinfo ]]; then
      NUM_CPU_CORES=$(grep -c "^processor" /proc/cpuinfo 2>/dev/null)
    fi
  fi

  # Attempt #5: POSIX getconf
  if [[ -z "$NUM_CPU_CORES" ]]; then
    if command -v getconf >/dev/null 2>&1; then
      NUM_CPU_CORES=$(getconf _NPROCESSORS_CONF 2>/dev/null)
    fi
  fi

  # Out of options: Default value
  if [[ -z "$NUM_CPU_CORES" ]] || [[ "$NUM_CPU_CORES" == "<calc_error>" ]]; then
    NUM_CPU_CORES="<unavailable>"
  fi

  echo "${NUM_CPU_CORES}"

} # display_num_cpu_cores()


# ----------------------------------------------------------------------------
#  FUNCTION NAME: display_num_cpu_hwthreads
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Display the number hardware threads for the CPU
#                  [Sockets] x [Cores-Per-Socket] x [Threads-Per-Core]
# ----------------------------------------------------------------------------
#  PARAMETERS   : na
# ----------------------------------------------------------------------------
function display_num_cpu_hwthreads()
{
  local NUM_CPU_HWTHREADS

  # Attempt #1: POSIX getconf for online processors (most direct)
  if command -v getconf >/dev/null 2>&1; then
    NUM_CPU_HWTHREADS=$(getconf _NPROCESSORS_ONLN 2>/dev/null)
  fi

  # Attempt #2: lscpu calculation
  if [[ -z "$NUM_CPU_HWTHREADS" ]]; then
    local num_cores
    num_cores=$(display_num_cpu_cores)

    # Only calculate if we got valid core count
    if [[ "${num_cores}" != "<unavailable>" ]] && [[ -n "${num_cores}" ]]; then
      local threads_per_core=1

      if lscpu >/dev/null 2>&1; then
        threads_per_core=$(lscpu | grep "Thread(s) per core:" | awk '{ print $4 }' | head -1 | tail -1 | tr -d '\r ')
      fi

      # Set minimum to 1
      if [[ "${threads_per_core}" -lt 1 ]] 2>/dev/null; then
        threads_per_core=1
      fi

      NUM_CPU_HWTHREADS=$(_greeting_calc "${num_cores} * ${threads_per_core}")
    fi
  fi

  # Attempt #3: nproc command
  if [[ -z "$NUM_CPU_HWTHREADS" ]] || [[ "$NUM_CPU_HWTHREADS" == "<calc_error>" ]]; then
    if command -v nproc >/dev/null 2>&1; then
      NUM_CPU_HWTHREADS=$(nproc 2>/dev/null)
    fi
  fi

  # Attempt #4: /proc/cpuinfo
  if [[ -z "$NUM_CPU_HWTHREADS" ]]; then
    if [[ -f /proc/cpuinfo ]]; then
      NUM_CPU_HWTHREADS=$(grep -c "^processor" /proc/cpuinfo 2>/dev/null)
    fi
  fi

  # Out of options: Default value
  if [[ -z "$NUM_CPU_HWTHREADS" ]] || [[ "$NUM_CPU_HWTHREADS" == "<calc_error>" ]]; then
    NUM_CPU_HWTHREADS="<unavailable>"
  fi

  echo "${NUM_CPU_HWTHREADS}"

} # display_num_cpu_hwthreads()


# ----------------------------------------------------------------------------
#  FUNCTION NAME: display_home_size_total
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Display the formatted total size of /home
# ----------------------------------------------------------------------------
#  PARAMETERS   : na
# ----------------------------------------------------------------------------
function display_home_size_total()
{
  # Skip on minimal mode or slow filesystems
  if [[ "${ENV_GREETING_MINIMAL}" == "1" ]] || _greeting_is_slow_filesystem ~ ; then
    echo "<skipped>"
    return
  fi

  # Verify home directory exists and is accessible
  if [[ ! -d ~ ]]; then
    echo "<unavailable>"
    return
  fi

  local home_size
  
  # Use df with -l and parse by mountpoint column ($NF)
  # Handles both one-line output and wrapped two-line output (RHEL6)
  if command -v timeout >/dev/null 2>&1; then
    home_size=$(timeout 1 df -hl ~ 2>/dev/null | awk 'NR>1 && NF>=5 && $NF ~ /^\// { if (NF >= 6) print $2; else print $1; exit }')
  else
    home_size=$(df -hl ~ 2>/dev/null | awk 'NR>1 && NF>=5 && $NF ~ /^\// { if (NF >= 6) print $2; else print $1; exit }')
  fi

  # Fallback: try without -l flag if -l not supported
  if [[ -z "${home_size}" ]]; then
    if command -v timeout >/dev/null 2>&1; then
      home_size=$(timeout 1 df -h ~ 2>/dev/null | awk 'NR>1 && NF>=5 && $NF ~ /^\// { if (NF >= 6) print $2; else print $1; exit }')
    else
      home_size=$(df -h ~ 2>/dev/null | awk 'NR>1 && NF>=5 && $NF ~ /^\// { if (NF >= 6) print $2; else print $1; exit }')
    fi
  fi

  echo "${home_size:-<unavailable>}"

} # display_home_size_total()


# ----------------------------------------------------------------------------
#  FUNCTION NAME: display_home_size_free
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Display the formatted free size of /home
# ----------------------------------------------------------------------------
#  PARAMETERS   : na
# ----------------------------------------------------------------------------
function display_home_size_free()
{
  # Skip on minimal mode or slow filesystems
  if [[ "${ENV_GREETING_MINIMAL}" == "1" ]] || _greeting_is_slow_filesystem ~ ; then
    echo "<skipped>"
    return
  fi

  # Verify home directory exists and is accessible
  if [[ ! -d ~ ]]; then
    echo "<unavailable>"
    return
  fi

  local home_free
  
  # Use df with -l and parse by mountpoint column ($NF)
  # Handles both one-line output and wrapped two-line output (RHEL6)
  if command -v timeout >/dev/null 2>&1; then
    home_free=$(timeout 1 df -hl ~ 2>/dev/null | awk 'NR>1 && NF>=5 && $NF ~ /^\// { if (NF >= 6) print $4; else print $3; exit }')
  else
    home_free=$(df -hl ~ 2>/dev/null | awk 'NR>1 && NF>=5 && $NF ~ /^\// { if (NF >= 6) print $4; else print $3; exit }')
  fi

