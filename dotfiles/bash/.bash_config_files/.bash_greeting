    else
      home_free=$(df -h ~ 2>/dev/null | awk 'NR>1 && NF>=5 && $NF ~ /^\// { if (NF >= 6) print $4; else print $3; exit }')
    fi
  fi

  echo "${home_free:-<unavailable>}"

} # display_home_size_free()


# ----------------------------------------------------------------------------
#  FUNCTION NAME: display_mem_total
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Display the total amount of system ram (in GB)
# ----------------------------------------------------------------------------
#  PARAMETERS   : na
# ----------------------------------------------------------------------------
function display_mem_total()
{
  # Attempt #1: Parse /proc/meminfo for memory (in kB)
  if [ -f "/proc/meminfo" ]; then
    MEM_SIZE=$( awk '/MemTotal/ { print $2 }' /proc/meminfo )
  else
    MEM_SIZE=""
  fi

  # Attempt #2:  Parse sysctl results for memory (in bytes) (macOS)
  if [[ -z "$MEM_SIZE" ]]; then
    # Check if available
    if sysctl -n hw.memsize  >/dev/null 2>&1; then
      MEM_SIZE=$(sysctl -n hw.memsize)
      MEM_SIZE=$(_greeting_calc "${MEM_SIZE} / 1024")
    fi
  fi

  # Attempt #3:  Parse sysctl results for memory (in bytes) (FreeBSD)
  if [[ -z "$MEM_SIZE" ]]; then
    # Check if available
    if sysctl -n hw.physmem  >/dev/null 2>&1; then
      MEM_SIZE=$(sysctl -n hw.physmem)
      MEM_SIZE=$(_greeting_calc "${MEM_SIZE} / 1024")
    fi
  fi


  # Convert kB into GB)
  if [[ -z "$MEM_SIZE" ]]; then
    MEM_SIZE="<unavailable>"
  else
    MEM_SIZE=$(_greeting_calc "${MEM_SIZE} / 1024 / 1024")
  fi

  echo "${MEM_SIZE}"

} # display_mem_total()


# ----------------------------------------------------------------------------
#  FUNCTION NAME: display_mem_free
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Display the free amount of system ram (in GB)
# ----------------------------------------------------------------------------
#  PARAMETERS   : na
# ----------------------------------------------------------------------------
function display_mem_free()
{
  # Attempt #1: Parse /proc/meminfo for memory (in kB) - MemAvailable preferred
  if [ -f "/proc/meminfo" ]; then
    MEM_FREE=$( awk '/MemAvailable/ { print $2 }' /proc/meminfo )
  fi

  # Attempt #2: Parse /proc/meminfo for memory (in kB) - MemFree fallback
  if [[ -z "$MEM_FREE" ]]; then
    if [ -f "/proc/meminfo" ]; then
      MEM_FREE=$( awk '/MemFree/ { print $2 }' /proc/meminfo )
    fi
  fi

  # Attempt #3: Parse sysctl results for memory (in bytes) - macOS
  if [[ -z "$MEM_FREE" ]]; then
    if command -v vm_stat >/dev/null 2>&1; then
      # macOS vm_stat gives pages, need to multiply by page size
      local page_size
      page_size=$(sysctl -n hw.pagesize 2>/dev/null)
      if [[ -n "${page_size}" ]]; then
        local free_pages
        free_pages=$(vm_stat | awk '/Pages free/ { print $3 }' | tr -d '.')
        if [[ -n "${free_pages}" ]]; then
          MEM_FREE=$(_greeting_calc "${page_size} * ${free_pages} / 1024")
        fi
      fi
    fi
  fi

  # Attempt #4: Parse sysctl results for memory (in bytes) - FreeBSD
  if [[ -z "$MEM_FREE" ]]; then
    if sysctl -n hw.pagesize >/dev/null 2>&1; then
      page_size=$(sysctl -n hw.pagesize)

      if sysctl -n vm.stats.vm.v_free_count >/dev/null 2>&1; then
        free_bytes_per_page=$(sysctl -n vm.stats.vm.v_free_count)
        MEM_FREE=$(_greeting_calc "${page_size} * ${free_bytes_per_page} / 1024")
      fi
    fi
  fi

  # Convert kB into GB
  if [[ -z "$MEM_FREE" ]] || [[ "$MEM_FREE" == "<calc_error>" ]]; then
    MEM_FREE="<unavailable>"
  else
    MEM_FREE=$(_greeting_calc "${MEM_FREE} / 1024 / 1024")
  fi

  echo "${MEM_FREE}"

} # display_mem_free()


# ----------------------------------------------------------------------------
#  FUNCTION NAME: display_os_version
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Display the detected operating system version
# ----------------------------------------------------------------------------
#  PARAMETERS   : na
# ----------------------------------------------------------------------------
function display_os_version()
{
  local os_version=""
  local release_file=""

  # Linux distro release files (prefer explicit one-line release text)
  #  - Note: Keep /etc/redhat-release first, then scan
  #          common release-file patterns
  for release_file in /etc/redhat-release /etc/*-release /etc/*_release /etc/release; do
    if [[ -f "${release_file}" ]]; then
      case "${release_file}" in
        /etc/os-release|/etc/lsb-release)
          continue
          ;;
      esac

      os_version=$(head -n 1 "${release_file}")
      if [[ -n "${os_version}" ]]; then
        break
      fi
    fi
  done

  # Generic Linux fallback
  if [[ -z "${os_version}" && -f /etc/os-release ]]; then
    os_version=$(awk -F= '/^PRETTY_NAME=/{gsub(/"/,"",$2); print $2; exit}' /etc/os-release)
  fi

  # LSB fallback (if PRETTY_NAME is unavailable)
  if [[ -z "${os_version}" && -f /etc/lsb-release ]]; then
    os_version=$(awk -F= '/^DISTRIB_DESCRIPTION=/{gsub(/"/,"",$2); print $2; exit}' /etc/lsb-release)
  fi

  # Debian fallback
  if [[ -z "${os_version}" && -f /etc/debian_version ]]; then
    os_version="Debian $(head -n 1 /etc/debian_version)"
  fi

  # BSD/macOS fallback
  if [[ -z "${os_version}" ]]; then
    case "$(uname -s 2>/dev/null)" in
      FreeBSD|OpenBSD|NetBSD|DragonFly)
        os_version="$(uname -s) $(uname -r)"
        ;;
      Darwin)
        if command -v sw_vers >/dev/null 2>&1; then
          os_version="$(sw_vers -productName) $(sw_vers -productVersion)"
        else
          os_version="Darwin $(uname -r)"
        fi
        ;;
      CYGWIN*|MINGW*|MSYS*)
        os_version="$(uname -s) $(uname -r)"
        ;;
      Linux)
        os_version="Linux $(uname -r)"
        ;;
    esac
  fi

  if [[ -z "${os_version}" ]]; then
    os_version="<unknown>"
  fi

  echo "${os_version}"

} # display_os_version()


# ----------------------------------------------------------------------------
#  FUNCTION NAME: display_greeting
# ----------------------------------------------------------------------------
#  DESCRIPTION  : Display the system greeting
# ----------------------------------------------------------------------------
#  PARAMETERS   : na
# ----------------------------------------------------------------------------
function display_greeting()
{
  # Fetch system information
  local sys_user
  sys_user="$USER"

  local sys_host
  sys_host=$(hostname)

  local sys_kernel_name
  sys_kernel_name=$(uname -s)

  local sys_kernel_rel
  sys_kernel_rel=$(uname -r)

  local sys_kernel_arch
  sys_kernel_arch=$(uname -m)

  local sys_os_version
  sys_os_version=$(display_os_version)

  local sys_cpu
  sys_cpu=$(display_processor_name)

  local sys_cpu_cores
  sys_cpu_cores=$(display_num_cpu_cores)

  local sys_cpu_threads
  sys_cpu_threads=$(display_num_cpu_hwthreads)

  local sys_homedir_size
  sys_homedir_size=$(display_home_size_total)

  local sys_homedir_free
  sys_homedir_free=$(display_home_size_free)

  local sys_mem_size
  sys_mem_size=$(display_mem_total)

  local sys_mem_free
  sys_mem_free=$(display_mem_free)

  local sys_uptime
  sys_uptime=$(display_system_uptime)


  # Display Greeting
  echo ""
  echo -e  "\n\e(0lqq\e(B[ ${TC_BLU}Welcome${TC_OFF} ]\e(0qqqqqqqqq\e(B" 
  echo -e  "\e(0x\e(B"
  echo -e  "\e(0x\e(B ${TC_CYN}Date${TC_OFF} : $(date '+%Y %B %d') (${TC_GRN}$(date '+%A')${TC_OFF})"
  echo -e  "\e(0x\e(B ${TC_CYN}Time${TC_OFF} : $(date '+%r') ${TC_DRK}$(date '+%Z')${TC_OFF}"
  echo -e  "\e(0x\e(B ${TC_CYN}Host${TC_OFF} : ${TC_YEL}${sys_user}${TC_OFF} @ ${TC_YEL}${sys_host}${TC_OFF}"
  echo -e  "\e(0x\e(B  - ${TC_MAG}system${TC_OFF}    : ${sys_kernel_name} ${TC_MAG}|${TC_OFF} ${sys_kernel_rel} ${TC_MAG}|${TC_OFF} ${sys_kernel_arch}"
  echo -e  "\e(0x\e(B  - ${TC_MAG}os ver${TC_OFF}    : ${sys_os_version}"
  echo -e  "\e(0x\e(B  - ${TC_MAG}processor${TC_OFF} : ${sys_cpu} ${TC_MAG}|${TC_OFF} ${sys_cpu_cores}C/${sys_cpu_threads}T"
  echo -e  "\e(0x\e(B  - ${TC_MAG}ram${TC_OFF}       : ${sys_mem_size} GB total ${TC_MAG}|${TC_OFF} ${sys_mem_free} GB free"
  echo -e  "\e(0x\e(B  - ${TC_MAG}/home${TC_OFF}     : ${sys_homedir_size} total ${TC_MAG}|${TC_OFF} ${sys_homedir_free} free"
  echo -e  "\e(0x\e(B  - ${TC_MAG}uptime${TC_OFF}    : ${sys_uptime}"
  echo -en "\e(0mqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqq\e(B"
  echo -e  "\e(0qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqj\e(B"
  echo ""

} # display_greeting()


